rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Meetings: only owner can access
    match /meetings/{meetingId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // All subcollections: inherit meeting ownership
      match /transcript/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.userId == request.auth.uid;
      }

      match /summary/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.userId == request.auth.uid;
      }

      match /embeddings/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.userId == request.auth.uid;
      }

      match /chatHistory/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/meetings/$(meetingId)).data.userId == request.auth.uid;
      }
    }
  }
}
